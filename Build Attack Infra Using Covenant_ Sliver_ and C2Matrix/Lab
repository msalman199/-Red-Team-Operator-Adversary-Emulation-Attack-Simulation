cat > ~/redteam-lab/stop_infrastructure.sh << 'EOF'
#!/bin/bash
echo "Stopping Red Team Infrastructure..."

# Stop processes
pkill -f "dotnet run"
pkill -f "sliver-server"
pkill -f "manage.py runserver"

echo "All infrastructure services stopped."
EOF

