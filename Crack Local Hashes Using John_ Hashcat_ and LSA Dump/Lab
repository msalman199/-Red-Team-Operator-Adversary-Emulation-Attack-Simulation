Task 2: Password Cracking with John the Ripper
Step 1: Basic Dictionary Attack
# Check available formats
john --list=formats | grep -i "raw-md5"

# Crack MD5 hashes
john --format=Raw-MD5 --wordlist=wordlist.txt md5_hashes.txt

# View cracked passwords
john --show --format=Raw-MD5 md5_hashes.txt
Step 2: Rule-Based Attack
# Create custom rules file
cat > custom.rule << EOF
# Append digits
$1 $2 $3
$0 $0 $0
# Capitalize first letter
c
# Toggle case
t
EOF

# Apply rules during cracking
john --format=Raw-MD5 --wordlist=wordlist.txt --rules=custom md5_hashes.txt
Step 3: Crack SHA-256 Hashes
# Crack SHA-256 format
john --format=Raw-SHA256 --wordlist=wordlist.txt sha256_hashes.txt

# Show results
john --show --format=Raw-SHA256 sha256_hashes.txt
Step 4: Check Cracking Status
# View current session status
john --status

# Resume interrupted session
john --restore
Task 3: Advanced Cracking with Hashcat
Step 1: Dictionary Attack with Hashcat
# MD5 hash mode is 0
hashcat -m 0 -a 0 md5_hashes.txt wordlist.txt

# Show cracked hashes
hashcat -m 0 md5_hashes.txt --show
Step 2: Rule-Based Attack
# Use built-in best64 rule
hashcat -m 0 -a 0 md5_hashes.txt wordlist.txt -r /usr/share/hashcat/rules/best64.rule

# View results
hashcat -m 0 md5_hashes.txt --show
Step 3: Mask Attack (Brute Force)
# Mask: 4 lowercase letters + 2 digits
# ?l = lowercase, ?d = digit
hashcat -m 0 -a 3 md5_hashes.txt ?l?l?l?l?d?d

# Custom mask for common patterns
hashcat -m 0 -a 3 md5_hashes.txt ?u?l?l?l?l?d?d
Step 4: Hybrid Attack
# Wordlist + mask (append 2 digits)
hashcat -m 0 -a 6 md5_hashes.txt wordlist.txt ?d?d

# Mask + wordlist (prepend 2 digits)
hashcat -m 0 -a 7 md5_hashes.txt ?d?d wordlist.txt
Step 5: Crack NTLM Hashes
# Extract NTLM hash portion (4th field)
cut -d: -f4 ntlm_hashes.txt > ntlm_only.txt

# NTLM hash mode is 1000
hashcat -m 1000 -a 0 ntlm_only.txt wordlist.txt

# Show results
hashcat -m 1000 ntlm_only.txt --show
