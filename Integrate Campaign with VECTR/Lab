Task 1: Install and Configure VECTR
Step 1.1: Install Docker Components
# Update system and install Docker
sudo apt update && sudo apt upgrade -y
sudo apt install -y docker.io docker-compose

# Add user to docker group
sudo usermod -aG docker $USER
newgrp docker

# Verify installation
docker --version
docker-compose --version
Step 1.2: Deploy VECTR
# Create working directory
mkdir -p ~/vectr-lab && cd ~/vectr-lab

# Clone VECTR repository
git clone https://github.com/SecurityRiskAdvisors/VECTR.git
cd VECTR

# Create environment configuration
cat > .env << 'EOF'
VECTR_HOSTNAME=localhost
VECTR_PORT=8081
VECTR_DATA_KEY=change-this-secret-key
MONGO_INITDB_ROOT_USERNAME=vectr
MONGO_INITDB_ROOT_PASSWORD=vectr123!
EOF

chmod 600 .env
Step 1.3: Start VECTR Services
# Launch VECTR containers
docker-compose up -d

# Verify containers are running
docker-compose ps

# Wait for initialization (2-3 minutes)
sleep 180

# Check service health
curl -k https://localhost:8081/health
Step 1.4: Access VECTR Interface
# Display access information
echo "VECTR URL: https://localhost:8081"
echo "Default Username: admin"
echo "Default Password: 11_ThisIsTheFirstPassword_11"
Access the web interface and change the default password immediately.

