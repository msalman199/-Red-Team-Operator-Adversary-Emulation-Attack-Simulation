Step 1.3: Deploy Target Containers
Create docker-compose.yml:

version: '3.8'
services:
  target1:
    image: ubuntu:20.04
    container_name: target1
    networks:
      pivot-lab:
        ipv4_address: 192.168.100.10
    command: >
      bash -c "apt update && apt install -y openssh-server &&
      echo 'root:password123' | chpasswd &&
