Task 1: Install and Configure Caddy Web Server
Step 1.1: Install Caddy
# Update system and install dependencies
sudo apt update && sudo apt upgrade -y
sudo apt install -y curl wget gnupg2

# Add Caddy repository
curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/gpg.key' | \
  sudo gpg --dearmor -o /usr/share/keyrings/caddy-stable-archive-keyring.gpg

curl -1sLf 'https://dl.cloudsmith.io/public/caddy/stable/debian.deb.txt' | \
  sudo tee /etc/apt/sources.list.d/caddy-stable.list

# Install Caddy
sudo apt update
sudo apt install caddy -y

# Verify installation
caddy version
Step 1.2: Create Directory Structure
# Create working directories
mkdir -p ~/c2-lab/{config,scripts,logs}
cd ~/c2-lab

# Add test domain to hosts file
echo "127.0.0.1 c2.local" | sudo tee -a /etc/hosts
Step 1.3: Configure Caddyfile
cat > config/Caddyfile << 'EOF'
localhost:8443 {
    tls internal
    reverse_proxy localhost:8080
    
    log {
        output file logs/caddy.log
        format json
    }
    
    header {
        -Server
        X-Frame-Options "DENY"
        X-Content-Type-Options "nosniff"
    }
}

c2.local:8443 {
    tls internal
    reverse_proxy localhost:8080
    
    log {
        output file logs/caddy-domain.log
    }
}
EOF

# Validate configuration
caddy validate --config config/Caddyfile
